<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PiConsole" parent="android:Theme.Material.Light.NoActionBar" />
    
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">#11121C</item>
        <!-- Set the splash screen icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <!-- Set the post-splash theme -->
        <item name="postSplashScreenTheme">@style/Theme.PiConsole</item>
    </style>
</resources>
